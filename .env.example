# Flask web application port
PORT=5001

# Flask application environment (development / production)
FLASK_ENV=development

# Database configuration URL
# SQLite default: sqlite:///data/covid19.db
# PostgreSQL alternative: postgresql://postgres:postgres@localhost:5432/covid19
DATABASE_URL=sqlite:///data/covid19.db

# Flask caching strategy (SimpleCache for single process, RedisCache or Memcached for production)
CACHE_TYPE=SimpleCache
REDIS_URL=redis://localhost:6379/0

# Flask rate-limiting configuration
LIMITER_DEFAULT_LIMITS="200 per day;50 per hour"

# Application logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Flask Secret Key for session cookie signing
SECRET_KEY=generate-a-secure-random-key-for-production-de31c77fef6a
